<?xml version="1.0" encoding="utf-8"?>
<!--
    Allow cleartext HTTP traffic only to the backend domain.
    All other traffic is restricted to HTTPS.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">kamintransbus-transfer.de</domain>
    </domain-config>
</network-security-config>
